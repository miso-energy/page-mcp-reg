              "opengraphImageUrl": "https://opengraph.githubassets.com/6073e3a67a921d05f9c328f0f78ca20ee37b021584f7a296289ff556902cefcf/chroma-core/chroma-mcp",
              "ownerAvatarUrl": "https://avatars.githubusercontent.com/u/105881770?v=4",
              "preferredImage": "https://avatars.githubusercontent.com/u/105881770?v=4",
