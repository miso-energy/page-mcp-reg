              "opengraphImageUrl": "https://opengraph.githubassets.com/d6975bcac942dd15763d27219d9e9aa9db6bccc36908a2634f0da5a3e9484725/mlava/agent-ready-mcp",
              "ownerAvatarUrl": "https://avatars.githubusercontent.com/u/6857790?v=4",
