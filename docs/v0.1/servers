              "opengraphImageUrl": "https://opengraph.githubassets.com/5f44a55e83a91c6e05ab1d1b3c9166cabfde27cd65a6d93babad7e4847cec8c1/SAP/open-ux-tools",
              "ownerAvatarUrl": "https://avatars.githubusercontent.com/u/2531208?v=4",
