              "opengraphImageUrl": "https://opengraph.githubassets.com/78d9fba19ee873f2d2c92d4d298ced70cf910d0f7cf666146023ac6d5a88d776/tavily-ai/tavily-mcp",
              "ownerAvatarUrl": "https://avatars.githubusercontent.com/u/170207473?v=4",
              "preferredImage": "https://avatars.githubusercontent.com/u/170207473?v=4",
